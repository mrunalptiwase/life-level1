// Firestore Security Rules for Life Leveling App

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Users can read/write their own tasks
    match /tasks/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Users can read/write their own transactions
    match /transactions/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Withdrawals: Users can create their own withdrawal requests
    // Only authenticated users can create withdrawals
    // Admin (specific email) can read/write all withdrawals
    match /withdrawals/{withdrawalId} {
      allow create: if request.auth != null &&
                       request.auth.uid == resource.data.userId &&
                       request.data.status == "pending" &&
                       request.data.amount >= 200 &&
                       request.data.coinsUsed == math.ceil(request.data.amount / 0.1);
      allow read: if request.auth != null &&
                     (request.auth.uid == resource.data.userId ||
                      request.auth.token.email == "mrunaltiwase@gmail.com");
      allow update: if request.auth != null &&
                       request.auth.token.email == "mrunaltiwase@gmail.com" &&
                       (request.data.diff(resource.data).affectedKeys() == ["status"].toSet() ||
                        (request.data.diff(resource.data).affectedKeys() == ["status"].toSet() &&
                         request.data.status in ["approved", "rejected"]));
    }

    // Leaderboard: Read-only for all authenticated users
    match /leaderboard/{document=**} {
      allow read: if request.auth != null;
    }

    // Friends, teams, seasons: Add rules as needed
    match /friends/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /teams/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /seasons/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Reports: Admin only
    match /reports/{document=**} {
      allow read, write: if request.auth != null && request.auth.token.email == "mrunaltiwase@gmail.com";
    }
  }
}
